<%- include('partials/header', { title: 'ExpenseIQ — Smart Finance Tracker' }) %>

<nav class="home-nav" id="navbar">
  <a href="/" class="logo">
    <div class="logo-icon">₹</div>
    <span class="logo-text">ExpenseIQ</span>
  </a>
  <ul class="nav-links">
    <li><a href="#features">Features</a></li>
    <li><a href="#how-it-works">How it Works</a></li>
    <li><a href="#about">About</a></li>
  </ul>
  <div class="nav-actions">
    <a href="/auth/login" class="btn btn-outline btn-sm">Login</a>
    <a href="/auth/register" class="btn btn-primary btn-sm">Get Started Free</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-content">
    <div class="hero-badge">
      <svg data-feather="zap" width="13" height="13"></svg>
      Smart Finance Tracker for Everyone
    </div>
    <h1 class="hero-title">
      Track Every Rupee,<br />
      <span class="highlight">Build Real Wealth</span>
    </h1>
    <p class="hero-subtitle">
      ExpenseIQ helps you record income & expenses, visualize spending patterns,
      set budgets, and make smarter financial decisions — all in one simple dashboard.
    </p>
    <div class="hero-actions">
      <a href="/auth/register" class="btn btn-primary btn-lg">
        <svg data-feather="arrow-right" width="18" height="18"></svg>
        Start Tracking Free
      </a>
      <a href="/auth/login" class="btn btn-outline btn-lg">
        <svg data-feather="log-in" width="18" height="18"></svg>
        Already have account?
      </a>
    </div>
    <div class="hero-stats">
      <div class="stat-card">
        <span class="stat-num">₹0</span>
        <span class="stat-label">Cost to Use</span>
      </div>
      <div class="stat-card">
        <span class="stat-num">10+</span>
        <span class="stat-label">Chart Views</span>
      </div>
      <div class="stat-card">
        <span class="stat-num">6</span>
        <span class="stat-label">Categories</span>
      </div>
      <div class="stat-card">
        <span class="stat-num">100%</span>
        <span class="stat-label">Private & Safe</span>
      </div>
    </div>
  </div>
</section>

<section class="section" id="features">
  <div style="text-align:center;max-width:600px;margin:0 auto;">
    <span class="section-tag">Features</span>
    <h2 class="section-title">Everything you need to manage money</h2>
    <p class="section-subtitle" style="margin:0 auto 50px;">
      Simple tools that give you complete visibility over where your money goes every month.
    </p>
  </div>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(0,200,150,0.12);color:var(--income);">
        <svg data-feather="plus-circle" width="24" height="24"></svg>
      </div>
      <h3>Add Transactions Instantly</h3>
      <p>Log any income or expense in seconds. Add title, amount, category, date, and notes — all from one simple form.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(79,141,255,0.12);color:var(--savings);">
        <svg data-feather="pie-chart" width="24" height="24"></svg>
      </div>
      <h3>Visual Charts & Reports</h3>
      <p>See your spending in pie charts, bar graphs, and line charts. Understand where every rupee is going at a glance.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(245,158,11,0.12);color:var(--balance);">
        <svg data-feather="target" width="24" height="24"></svg>
      </div>
      <h3>Set Monthly Budgets</h3>
      <p>Define spending limits per category. Get warned before you overspend on Food, Travel, Shopping, and more.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(255,77,109,0.12);color:var(--expense);">
        <svg data-feather="filter" width="24" height="24"></svg>
      </div>
      <h3>Filter & Search</h3>
      <p>Find any transaction instantly. Filter by category, date range, or type. Sort by amount or newest first.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(167,139,250,0.12);color:var(--purple);">
        <svg data-feather="download" width="24" height="24"></svg>
      </div>
      <h3>Export Reports</h3>
      <p>Download your financial data as PDF or CSV. Share monthly summaries with anyone or save for your records.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(0,200,150,0.12);color:var(--income);">
        <svg data-feather="shield" width="24" height="24"></svg>
      </div>
      <h3>Secure & Private</h3>
      <p>Your data is protected with JWT authentication and bcrypt password hashing. Only you can access your finances.</p>
    </div>
  </div>
</section>

<section class="section" id="how-it-works"
         style="background:var(--bg-card);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
  <div style="text-align:center;max-width:500px;margin:0 auto;">
    <span class="section-tag">Simple Process</span>
    <h2 class="section-title">Up and running in 3 steps</h2>
    <p class="section-subtitle" style="margin:0 auto 50px;">
      No complicated setup. Just sign up and start tracking.
    </p>
  </div>
  <div class="steps-grid" style="max-width:800px;margin:0 auto;">
    <div class="step-card">
      <div class="step-num">1</div>
      <h3>Create Your Account</h3>
      <p>Register with your email and password. Takes less than 60 seconds.</p>
    </div>
    <div class="step-card">
      <div class="step-num">2</div>
      <h3>Add Your Transactions</h3>
      <p>Start logging income and expenses. Categorize them your way.</p>
    </div>
    <div class="step-card">
      <div class="step-num">3</div>
      <h3>See Your Insights</h3>
      <p>View charts, set budgets, and understand your financial patterns.</p>
    </div>
  </div>
</section>

<section class="section" style="text-align:center;">
  <div style="max-width:520px;margin:0 auto;">
    <h2 class="section-title">Ready to take control of your money?</h2>
    <p style="color:var(--text-2);margin:14px 0 32px;font-size:16px;">
      Join ExpenseIQ today — it's completely free.
    </p>
    <a href="/auth/register" class="btn btn-primary btn-lg">
      <svg data-feather="arrow-right" width="18" height="18"></svg>
      Create Free Account
    </a>
  </div>
</section>

<script>
  feather.replace();
  window.addEventListener('scroll', function() {
    const nav = document.getElementById('navbar');
    nav.style.boxShadow = window.scrollY > 20 ? '0 4px 30px rgba(0,0,0,0.4)' : 'none';
  });
</script>

</body>
</html>
